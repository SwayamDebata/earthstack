# Public Mapbox token (used by browser map components).
# Get one at https://account.mapbox.com/access-tokens/ and paste below.
NEXT_PUBLIC_MAPBOX_TOKEN=

# Optional: server-only base URL for /api/proxy (overrides NEXT_PUBLIC_* on the server)
# API_BASE_URL=https://api.modelearth.in

# Optional: upstream timeout for proxy fetch (ms)
# API_UPSTREAM_TIMEOUT_MS=45000

# Pilot access (preview vs full command)
# NEXT_PUBLIC_PILOT_DEV_UNLOCK=true          # unlock full dashboard locally
# NEXT_PUBLIC_PILOT_UNLOCK_CODE=ME-xxxx      # share privately after you approve a pilot
# PILOT_NOTIFY_EMAIL=you@example.com         # inbox for pilot form (Vercel: server only)
# RESEND_API_KEY=re_...                      # https://resend.com
# RESEND_FROM_EMAIL=onboarding@resend.dev    # or ModelEarth <notify@modelearth.in> after domain verify
# PILOT_REQUEST_AUTO_REPLY=false             # set to false to skip ack email to requester
# PILOT_REQUEST_WEBHOOK_URL=https://...      # optional extra webhook (Slack/Discord)
